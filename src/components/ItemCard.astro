---
import type { InboxItem } from '../lib/data';
import { TIER_LABELS } from '../lib/data';
const { item } = Astro.props as { item: InboxItem };
---
<a href={`/item/${item.id}`} class="card" data-pillar={item.pillar} data-tier={item.tier}>
  <div class="card-meta">
    <span class="feed-name">{item.feed}</span>
    <span class={`tier-badge ${item.tier}`}>{TIER_LABELS[item.tier]}</span>
    <span class={`signal-badge signal-${item.signal_strength}`}>
      {item.signal_strength === 'high' ? '高信号' : item.signal_strength === 'medium' ? '中信号' : '低信号'}
    </span>
    <span>{(item.published || '').slice(0, 10)}</span>
  </div>
  <h3 class="card-title">{item.title}</h3>
  <p class="card-summary">{item.structured_summary.background}</p>
  <div class="takeaway">{item.executive_takeaway}</div>
  <div class="tags">
    {item.tags.map(t => <span class="tag">{t}</span>)}
  </div>
</a>
